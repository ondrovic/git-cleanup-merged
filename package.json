{
  "name": "git-cleanup-merged",
  "version": "1.0.5",
  "description": "Clean up local Git branches that have merged PRs on GitHub",
  "main": "index.js",
  "bin": {
    "git-cleanup-merged": "./src/bin.js"
  },
  "scripts": {
    "test": "jest",
    "test:coverage": "jest --coverage",
    "test:coverage:ci": "jest --coverage && node scripts/fix-junit.js",
    "lint": "eslint .",
    "format": "prettier --write ."
  },
  "keywords": [
    "git",
    "github",
    "cli",
    "cleanup",
    "branches",
    "merge"
  ],
  "author": "Chris Ondrovic",
  "license": "MIT",
  "engines": {
    "node": ">=20.19.0"
  },
  "preferGlobal": true,
  "files": [
    "src/**/*.js",
    "index.js",
    "README.md",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/ondro/git-cleanup-merged.git"
  },
  "bugs": {
    "url": "https://github.com/ondro/git-cleanup-merged/issues"
  },
  "homepage": "https://github.com/ondro/git-cleanup-merged#readme",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.5.0",
    "globals": "^17.7.0",
    "jest": "^30.4.2",
    "jest-junit": "^17.0.0",
    "prettier": "^3.8.4"
  },
  "jest": {
    "coverageThreshold": {
      "global": {
        "branches": 75
      }
    },
    "collectCoverageFrom": [
      "src/**/*.js",
      "!src/bin.js"
    ],
    "coverageReporters": [
      "text",
      "lcov",
      "html"
    ],
    "reporters": [
      "default",
      [
        "jest-junit",
        {
          "outputDirectory": "coverage",
          "outputName": "junit.xml",
          "classNameTemplate": "{filepath}",
          "titleTemplate": "{title}",
          "ancestorSeparator": " › ",
          "usePathForSuiteName": true
        }
      ]
    ]
  },
  "packageManager": "yarn@1.22.19+sha512.ff4579ab459bb25aa7c0ff75b62acebe576f6084b36aa842971cf250a5d8c6cd3bc9420b22ce63c7f93a0857bc6ef29291db39c3e7a23aab5adfd5a4dd6c5d71"
}
